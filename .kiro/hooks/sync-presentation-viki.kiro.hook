{
  "enabled": true,
  "name": "Sync Presentation to Viki",
  "description": "When presentation.html is edited, automatically copy it to the viki html directory so it's served at the public URL.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/presentation.html"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cp /root/AiAgent/automation/presentation.html /root/viki/html/ai-presentation.html"
  }
}